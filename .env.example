# Either an OpenAI key or an OpenRouter key can run the complete pipeline.
OPENAI_API_KEY=
# LLM_API_KEY=sk-or-v1-...

# Optional overrides. OpenRouter is detected automatically from its key prefix.
# OPENVERSE_API_TOKEN=
# LLM_BASE_URL=https://api.openai.com/v1
# Defaults: gpt-4o-transcribe-diarize for OpenAI, openai/whisper-large-v3 for OpenRouter.
# TRANSCRIPTION_MODEL=
# DISABLE_TRANSCRIPTION=false
# Defaults: gpt-5.6-sol for OpenAI, openai/gpt-5.6-sol for OpenRouter.
# EDITOR_MODEL=
# EDITOR_MAX_TURNS=50
# DEBUG=true
# VIDEO_CONCURRENCY=2
# TRANSCRIPTION_CONCURRENCY=2
